{{ form_start(form) }}
<div class="d-flex justify-content-center">
    <div class="mb-3" style="width: 100%; max-width: 28rem;">
        <div class="input-group rounded-pill overflow-hidden shadow-sm">

            {{ form_widget(form.q, {
                'attr': {
                    'class': 'form-control border-0',
                    'placeholder': 'Recherche via un mot clé...'
                }
            }) }}

            <button
                type="submit"
                id="button-addon2"
                class="btn btn-primary d-flex align-items-center justify-content-center px-3">

                <svg aria-hidden="true" focusable="false" data-prefix="fas" data-icon="search"
                    width="16" height="16" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                    <path fill="currentColor" d="M505 442.7L405.3 343c-4.5-4.5-10.6-7.1-17-7H372c27.6-35.3 44-79.7 44-128C416 93.1 322.9 0 208 0S0 93.1 0 208s93.1 208 208 208c48.3 0 92.7-16.4 128-44v16.3c0 6.4 2.5 12.5 7 17l99.7 99.7c9.4 9.4 24.6 9.4 33.9 0l28.3-28.3c9.4-9.4 9.4-24.6 0-33.9zM208 336c-70.7 0-128-57.2-128-128S137.3 80 208 80s128 57.2 128 128-57.2 128-128 128z">
                    </path>
                </svg>
            </button>

        </div>
    </div>
</div>
{{ form_end(form) }}
